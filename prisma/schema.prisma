generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Participant {
  id                 String             @id @default(cuid())
  fullName           String
  phone              String
  age                Int
  gender             Gender
  maritalStatus      MaritalStatus
  occupation         String
  address            String
  churchName         String
  ministryArea       String
  needsAccommodation Boolean            @default(false)
  needsTshirt        Boolean            @default(false)
  paymentScreenshot  String             @default("")
  status             RegistrationStatus @default(PENDING)
  registrationNumber String?            @unique
  qrCode             String?
  sheetSynced        Boolean            @default(false)
  createdAt          DateTime           @default(now())
  scanLogs           ScanLog[]

  @@index([status])
  @@index([sheetSynced])
  @@index([fullName])
  @@index([phone])
  @@index([createdAt])
}

model ScanLog {
  id            String      @id @default(uuid())
  participantId String
  checkpoint    String
  scanDate      String      // YYYY-MM-DD date string for per-day deduplication
  scannedAt     DateTime    @default(now())
  scannedBy     String?

  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, checkpoint, scanDate])
  @@index([participantId])
  @@index([checkpoint])
  @@index([scannedAt])
  @@index([scanDate])
  @@index([scanDate, checkpoint])
}
enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String    // hashed
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())

  @@index([email])
}

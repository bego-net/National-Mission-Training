generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Participant {
  id                 String             @id @default(cuid())
  fullName           String
  phone              String
  age                Int
  gender             Gender
  maritalStatus      MaritalStatus
  occupation         String
  address            String
  churchName         String
  parishName         String
  ministryArea       String
  needsAccommodation Boolean            @default(false)
  paymentScreenshot  String             @default("")
  status             RegistrationStatus @default(PENDING)
  registrationNumber String?            @unique
  qrCode             String?
  scannedEntry       Boolean            @default(false)
  scannedLunch       Boolean            @default(false)
  scannedEntryAt     DateTime?
  scannedLunchAt     DateTime?
  createdAt          DateTime           @default(now())
  scanLogs           ScanLog[]

  @@index([status])
  @@index([fullName])
  @@index([phone])
  @@index([createdAt])
}

model ScanLog {
  id            String      @id @default(uuid())
  participantId String
  checkpoint    String
  scannedAt     DateTime    @default(now())
  scannedBy     String?

  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([checkpoint])
  @@index([scannedAt])
}
